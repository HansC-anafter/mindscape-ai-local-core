# ============================================
# HARD BARRIER: No cloud components in local-core
# ============================================
# These paths should always be empty; files here indicate architecture violations.
# All files installed via CapabilityInstaller should be excluded.
/web-console/src/app/capabilities/
!/web-console/src/app/capabilities/.gitkeep
/backend/app/capabilities/
!/backend/app/capabilities/.gitkeep

# Capability-installed playbooks (installed via API, not committed directly)
/backend/i18n/playbooks/
/backend/playbooks/
/backend/playbooks/specs/
/backend/app/playbooks/

# Capability-installed model directories (auto-ignored; whitelist core subdirs)
/backend/app/models/*/
!/backend/app/models/workspace/
!/backend/app/models/playbook_models/
!/backend/app/models/personal_governance/

# Ignore nested backend/backend/ directory (should not exist)
/backend/backend/

data/backups/
backups/
.backup/
*.dump
docs-internal/

