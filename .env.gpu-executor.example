# Mindscape AI Local Core - GPU Executor Node Example
# Copy to .env.gpu-executor on the GPU VM and fill in real values.

# -----------------------------------------------------------------------------
# Core node identity / control plane
# -----------------------------------------------------------------------------
CLOUD_CONNECTOR_ENABLED=true
EXECUTION_CONTROL_API_URL=https://site-hub.example.com
# Optional. Leave blank to derive ws:// or wss:// from EXECUTION_CONTROL_API_URL.
EXECUTION_CONTROL_WS_URL=
SITE_HUB_API_URL=
SITE_HUB_WS_URL=
SITE_KEY=your-site-key
TENANT_ID=your-tenant-id
DEVICE_ID=gpu-executor-01

# OAuth / machine token used by CloudConnector websocket auth
CLOUD_PROVIDER_TOKEN=
CLOUD_API_TOKEN=

# -----------------------------------------------------------------------------
# Backend runtime
# -----------------------------------------------------------------------------
GPU_EXECUTOR_PORT=8200
LOG_LEVEL=INFO
TZ=Asia/Taipei
LOCAL_AUTH_SECRET=change-me-before-production
RUNTIME_ENCRYPTION_KEY=replace-with-fernet-key
PLAYBOOK_DISABLE_LEGACY=1
ENABLE_LLM_INTENT_EXTRACTOR=false

# -----------------------------------------------------------------------------
# Local Postgres / Redis
# -----------------------------------------------------------------------------
POSTGRES_CORE_DB=mindscape_gpu_executor
POSTGRES_VECTOR_DB=mindscape_gpu_executor_vectors
POSTGRES_CORE_USER=mindscape
POSTGRES_VECTOR_USER=mindscape
POSTGRES_CORE_PASSWORD=change-me
POSTGRES_VECTOR_PASSWORD=change-me
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Multimodal model endpoint
# -----------------------------------------------------------------------------
# Preferred for GPU VM bring-up: point at an OpenAI-compatible VLM service.
VISION_MODEL_BASE_URL=http://host.docker.internal:8210

# Optional aliases / legacy fallback
VLM_BASE_URL=
MLX_SERVER_HOST=

# Optional external provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_TOKEN=

# HuggingFace model cache on the VM host
HF_HOME=/opt/mindscape/huggingface-cache
