# LLM Providers (at least one required)
OPENAI_API_KEY=your_openai_api_key_here
# or
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=sqlite:///./data/mindscape.db

# PostgreSQL (optional, for vector storage)
POSTGRES_DB=mindscape_vectors
POSTGRES_USER=mindscape
POSTGRES_PASSWORD=test_only_password

# Security
LOCAL_AUTH_SECRET=test-only-secret-not-for-production

# Logging
LOG_LEVEL=INFO

# LLM Intent Extractor
ENABLE_LLM_INTENT_EXTRACTOR=true

# OCR Service
OCR_USE_GPU=false
OCR_LANG=ch

# Timezone
TZ=UTC
